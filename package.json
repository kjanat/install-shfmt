{
	"name": "install-shfmt",
	"version": "1.0.0",
	"private": true,
	"description": "GitHub Action to install the shfmt shell formatter with caching",
	"license": "MIT",
	"type": "module",
	"workspaces": [
		".",
		".github/actions/release"
	],
	"scripts": {
		"build": "bun build src/main.ts --outfile dist/main.mjs --format esm --minify --target node",
		"fmt": "dprint fmt",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@typescript/native-preview": "catalog:",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.10",
	"engines": {
		"node": ">=24, <25"
	},
	"volta": {
		"node": "24.14.0"
	},
	"catalog": {
		"@typescript/native-preview": "latest",
		"typescript": "^5.9.3",
		"@types/node": ">=24, <25",
		"@actions/github-script": "github:actions/github-script"
	}
}
